  private static void Pre_Spec_Procedures(Table csvTable, String mapname, String sheetName) {
        try {
            String sql = "SELECT ProcExecute FROM sivmaps WHERE sivprog = ?";

            try (Connection conn = Db.getConnection();
                 PreparedStatement ps = conn.prepareStatement(sql)) {

                String progName = "MAP_CEVA".equals(mapname)
                        ? mapname + "_" + sheetName
                        : mapname;

                ps.setString(1, progName);

                try (ResultSet rs = ps.executeQuery()) {
                    if (!rs.next()) return;

                    String glnProcExecute = rs.getString("ProcExecute");
                    if (glnProcExecute == null || glnProcExecute.trim().isEmpty()) return;

                    glnProcExecute = glnProcExecute.trim();

                    // Load class dynamically
                    Class<?> clazz = Class.forName("SIVInject.NET." + glnProcExecute);
                    if (clazz == null) return;

                    // Create instance
                    Object obj = clazz.getDeclaredConstructor().newInstance();

                    // Get the method ProcessCSVTable (expects Table and mapname)
                    Method method = clazz.getMethod("ProcessCSVTable", Table.class, String.class);

                    // Invoke method
                    Object result = method.invoke(obj, csvTable, mapname);

                    if (result != null && result instanceof Table) {
                        Table processedTable = (Table) result;

                        // Clear original table
                        csvTable.getRows().clear();
                        csvTable.getColumns().clear();
                        // Copy columns
                        csvTable.getColumns().addAll(processedTable.getColumns());
                        // Copy rows
                        for (Map<String, Object> row : processedTable.getRows()) {
                            csvTable.addRow(new HashMap<>(row)); // clone each row
                        }
                    }
                }
            }

        } catch (Exception ex) {
            ex.printStackTrace();
        }
    }

    private static Table postSpecProcedures(Table dtTransaction,String mapname) {

        try {

            String procExecute = null;


            try (Connection conn = Db.getConnection();
                 PreparedStatement ps = conn.prepareStatement(
                         "SELECT ProcExecute FROM sivmaps WHERE sivprog = ?"
                 )) {

                String sivProgKey;
                if (mapname == null || mapname.trim().isEmpty()) {
                    sivProgKey = mapname + "_" + CurrentSheetname;
                } else {
                    sivProgKey = mapname;
                }

                ps.setString(1, sivProgKey);

                try (ResultSet rs = ps.executeQuery()) {
                    if (rs.next()) {
                        procExecute = rs.getString(1);
                    }
                }
            }

            if (procExecute == null || procExecute.trim().isEmpty()) {
                return dtTransaction; // nothing to execute
            }

            procExecute = procExecute.toUpperCase();


            String className = "SIVInject.NET." + procExecute;

            Class<?> clazz;
            try {
                clazz = Class.forName(className);
            } catch (ClassNotFoundException e) {
                // Same behavior as .NET: silently return if class not found
                return dtTransaction;
            }

            Object instance = clazz.getDeclaredConstructor().newInstance();


            Method method = clazz.getMethod(
                    "ProcessTransactionTable",
                    Table.class,
                    String.class
            );


            Object result = method.invoke(instance, dtTransaction, mapname);

            if (result instanceof Table) {
                dtTransaction = (Table) result;
            }

        } catch (Exception ex) {
            ex.printStackTrace();


        }

        return dtTransaction;
    }


