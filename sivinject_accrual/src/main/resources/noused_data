     {
         Table table = new Table();

         try (Workbook workbook = WorkbookFactory.create(new File(xlsFilePath))) {

             if (SheetCount == 1 && sheetList.isEmpty()) {
                 List<String> allSheets = new ArrayList<>();
                 for (int i = 0; i < workbook.getNumberOfSheets(); i++) {
                     allSheets.add(workbook.getSheetName(i));
                 }
                 applyFixSheetLogic(allSheets);
             }
             // -------- MAP_CEVA fix --------
             if ("MAP_CEVA".equalsIgnoreCase(glc_mapped_to)) {
                 sheetList.remove("Unbilled");
             }

             if (currentSheetIndex >= sheetList.size()) {
                 return table;
             }

             Sheet sheet = workbook.getSheet(sheetList.get(currentSheetIndex));
             if (sheet == null) return table;

             CurrentSheetname = sheet.getSheetName();
             currentSheetIndex++;
             SheetCount = sheetList.size();

             int maxCols = 300;
             boolean headerProcessed = false;

             for (Row row : sheet) {

                 // -------- Header row --------
                 if (!headerProcessed) {
                     int colCount = Math.min(row.getLastCellNum(), maxCols);
                     for (int i = 1; i <= colCount; i++) {
                         table.addColumn("data" + i);
                     }
                     headerProcessed = true;
                     continue; // SKIP header row
                 }

                 // -------- Data rows --------
                 Map<String, Object> dataRow = table.newRow();

                 for (int i = 0; i < table.getColumns().size(); i++) {
                     Cell cell = row.getCell(i, Row.MissingCellPolicy.CREATE_NULL_AS_BLANK);
                     dataRow.put(
                             table.getColumns().get(i),
                             getCellValue(cell)
                     );
                 }

                 table.addRow(dataRow);
             }


         }
         catch (Exception ex)
         {
             ex.printStackTrace();
         }




         return table;
     }